{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/styles.css", "destination": "/docs/styles.css" },
    { "source": "/script.js", "destination": "/docs/script.js" },
    { "source": "/assets/(.*)", "destination": "/docs/assets/$1" },
    { "source": "/website/(.*)", "destination": "/website/$1" },
    { "source": "/", "destination": "/docs/index.html" }
  ]
}
